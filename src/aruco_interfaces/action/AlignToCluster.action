# Goal — sent by robot_application to start alignment
int32 cluster_id
float32 alignment_threshold     # correction_magnitude below which alignment is done (meters)
---
# Result — sent when aligned or aborted
uint8[] arms_to_pick            # arm indices that have an assigned pickable tag
bool success
---
# Feedback — streamed during alignment
geometry_msgs/Vector3 correction
float32 correction_magnitude
